# Environment Variables
# Copy this file to .env and fill in the values

# Deployed Work Proof Stylus NFT (used by mint + reputation UI; same value as your `cargo stylus deploy` address)
NEXT_PUBLIC_NFT_ADDRESS=

# Optional: Work Proof Stylus contract for reputation / mint panels. Falls back to NEXT_PUBLIC_NFT_ADDRESS when unset.
NEXT_PUBLIC_WORK_PROOF_NFT_ADDRESS=

# URL of the ERC721 deployment API
ERC721_DEPLOYMENT_API_URL=http://localhost:4001

# WalletConnect Cloud project ID for wallet connections (required)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Application name displayed in wallet dialogs
NEXT_PUBLIC_APP_NAME=My DApp